<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.garagelog.desktop.controller.MantenimientoFormController"
      spacing="12" minWidth="480" prefWidth="540" prefHeight="640" minHeight="480">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Nuevo Mantenimiento" styleClass="titulo-seccion"/>

    <GridPane hgap="8" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
        </columnConstraints>

        <Label text="Fecha" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <DatePicker fx:id="fechaPicker" maxWidth="Infinity"
                    GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="KM" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="kmField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Observaciones" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextArea fx:id="observacionesArea" prefRowCount="2" maxWidth="Infinity"
                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Label text="Piezas" styleClass="subtitulo"/>

    <HBox spacing="8" HBox.hgrow="ALWAYS">
        <ComboBox fx:id="piezaCombo" promptText="Seleccionar pieza" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="cantidadField" prefWidth="60" promptText="Cant."/>
        <TextField fx:id="precioField" prefWidth="100" promptText="Precio unit."/>
        <Button text="Agregar" onAction="#onAgregarPieza"/>
    </HBox>

    <TableView fx:id="piezasTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn text="Pieza" fx:id="colPiezaNombre"/>
            <TableColumn text="Cantidad" fx:id="colCantidad"/>
            <TableColumn text="Precio Unit." fx:id="colPrecio"/>
            <TableColumn text="Obs." fx:id="colPiezaObs"/>
        </columns>
    </TableView>

    <Button text="Quitar seleccionada" onAction="#onQuitarPieza"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Label text="Mano de obra"/>
        <TextField fx:id="manoObraField" prefWidth="120" promptText="0.00"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Label text="Coste Total"/>
        <TextField fx:id="costeField" prefWidth="120" editable="false"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Guardar" styleClass="btn-primary" onAction="#onGuardar"/>
        <Button text="Cancelar" onAction="#onCancelar"/>
    </HBox>
</VBox>
